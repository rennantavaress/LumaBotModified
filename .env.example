# =============================================================================
# PROVIDER DE IA
# =============================================================================

# Qual provider de IA usar. Opções: gemini | openai | deepseek
# Padrão: gemini
AI_PROVIDER=gemini

# Modelo específico a usar. Cada provider tem seu padrão se omitido:
#   gemini   → gemini-2.0-flash
#   openai   → gpt-4o-mini
#   deepseek → deepseek-chat
# Opcional
# AI_MODEL=

# =============================================================================
# API KEYS — apenas a do provider ativo é obrigatória
# =============================================================================

# Obrigatória se AI_PROVIDER=gemini (padrão)
GEMINI_API_KEY=

# Obrigatória se AI_PROVIDER=openai
# OPENAI_API_KEY=

# Obrigatória se AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=

# =============================================================================
# BUSCA NA WEB
# =============================================================================

# Chave do Tavily (https://tavily.com) para busca na internet.
# Opcional — sem ela, o Gemini usa Google Grounding como fallback.
# Com OpenAI ou DeepSeek, sem esta chave a busca web fica indisponível.
# TAVILY_API_KEY=

# =============================================================================
# BOT
# =============================================================================

# Número do dono do bot no formato internacional (ex: 5511999999999).
# Usado para conceder permissões especiais de administração.
# Opcional
# OWNER_NUMBER=

# Nível de log do Pino/Baileys. Opções: silent | error | warn | info | debug
# Padrão: silent
# LOG_LEVEL=silent

# =============================================================================
# DASHBOARD WEB
# =============================================================================

# Porta do servidor do dashboard.
# Padrão: 3000
# DASHBOARD_PORT=3000

# Senha de acesso ao dashboard. Deixe vazio para desabilitar autenticação.
# Opcional
# DASHBOARD_PASSWORD=

# Define true se o bot estiver atrás de um tunnel Cloudflare.
# Padrão: false
# CLOUDFLARE_TUNNEL=false

# =============================================================================
# AUTO-DEPLOY (opcional)
# =============================================================================

# Segredo HMAC do webhook do GitHub. Aponte um webhook (push) para
# POST /api/deploy. A cada push na main: git pull → instala deps → builda o
# dashboard → reinicia. Sem este valor, o endpoint /api/deploy fica desativado.
# DEPLOY_WEBHOOK_SECRET=
