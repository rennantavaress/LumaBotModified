FROM node:20-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    ffmpeg \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

RUN npm ci

COPY nodemon.json ./
COPY src ./src
COPY dashboard ./dashboard
COPY index.js ./

RUN mkdir -p auth_info data

ENV NODE_ENV=development
ENV LOG_LEVEL=debug
ENV DASHBOARD_PORT=3000

EXPOSE 3000

CMD ["npm", "run", "dashboard:dev"]
